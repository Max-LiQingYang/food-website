# ─────────────────────────────────────────────────────────────
# 美食食谱网站 — .gitignore
# ─────────────────────────────────────────────────────────────

# 环境变量（安全红线）
.env
.env.local
.env.*.local

# 依赖
node_modules/
.pnp
.pnp.js

# 构建产物
dist/
dist-ssr/
*.local
frontend/dist.tar.gz
*.tar.gz

# 测试覆盖率
coverage/
.nyc_output/

# IDE
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# 日志
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 临时文件
.tmp/
.cache/
*.tmp

# 数据库（本地 SQLite）
*.db
*.sqlite
*.sqlite3

# Docker 运行时数据（不提交容器内产生的持久化数据）
docker-compose.override.yml

# OS
Thumbs.db
ehthumbs.db
Desktop.ini

# Secrets / Keys（绝对不要提交！）
*.pem
*.key
credentials.json
service-account.json

# WorkBuddy workspace
.workbuddy/
backend/database.sqlite-journal

# QClaw agent runtime artifacts
.qclaw/

{
  "name": "food-website",
  "version": "1.0.0",
  "private": true,
  "description": "美食食谱网站 - 用户收藏食谱功能",
  "workspaces": [
    "frontend",
    "backend",
    "tests"
  ],
  "scripts": {
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:backend": "npm run dev --workspace=backend",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build:frontend": "npm run build --workspace=frontend",
    "start:backend": "npm run start --workspace=backend",
    "test": "npm run test --workspace=tests",
    "test:backend": "npm run test:backend --workspace=tests",
    "test:frontend": "npm run test:frontend --workspace=tests",
    "test:coverage": "npm run test:coverage --workspace=tests",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}

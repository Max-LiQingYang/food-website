# ─────────────────────────────────────────────────────────────
# 美食食谱网站 — 环境变量示例文件
# 复制此文件为 .env 后填写实际值
# ⚠️ 切勿将 .env 提交到 Git 仓库！
# ─────────────────────────────────────────────────────────────
# 在 .gitignore 中添加：.env

# ─────────────────────────────────────────────────────────────
# 1. 通用配置
# ─────────────────────────────────────────────────────────────
NODE_ENV=production

# 前后端端口（Docker 外部映射端口）
FRONTEND_PORT=80
BACKEND_PORT=3001

# ─────────────────────────────────────────────────────────────
# 2. 数据库配置（MySQL 8.0）
# ─────────────────────────────────────────────────────────────
DB_DIALECT=mysql
DB_HOST=mysql
DB_PORT=3306
DB_NAME=food_website
DB_USER=food_user
DB_PASS=change_me_in_production

# 连接池
DB_POOL_MAX=10
DB_POOL_MIN=2
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# MySQL Docker 容器内用户/密码
MYSQL_USER=food_user
MYSQL_PASSWORD=change_me_in_production
MYSQL_ROOT_PASSWORD=root_secret_change_me

# 宿主机 MySQL 端口（本地开发用）
MYSQL_PORT=3306

# ─────────────────────────────────────────────────────────────
# 3. Redis（可选，用于缓存 / Session）
# ─────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PORT_EXTERNAL=6379

# ─────────────────────────────────────────────────────────────
# 4. JWT 认证
# ⚠️ 生产环境必须使用强随机密钥，建议 64+ 字符
# ─────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_strong_random_secret_key_at_least_64_chars_long
JWT_EXPIRES_IN=7d

# ─────────────────────────────────────────────────────────────
# 5. CORS（允许的前端域名）
# 生产环境：填写实际域名，不要用通配符 *
# 示例：http://localhost,https://food.example.com
# ─────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost,https://food.example.com

# ─────────────────────────────────────────────────────────────
# 6. 限流（Rate Limiting）
# ─────────────────────────────────────────────────────────────
# 15 分钟时间窗口内最大请求数
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─────────────────────────────────────────────────────────────
# 7. 前端 API 地址（构建时注入 Vite bundle）
# 生产环境：反向代理模式下填写相对路径 /api
# 开发环境：填写 http://localhost:3001
# ─────────────────────────────────────────────────────────────
VITE_API_BASE_URL=/api

# ─────────────────────────────────────────────────────────────
# 8. 日志级别（debug / info / warn / error）
# ─────────────────────────────────────────────────────────────
LOG_LEVEL=info

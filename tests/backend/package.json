{
  "name": "food-website-backend-tests",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test": "jest --coverage",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.3.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterFramework": [],
    "testMatch": ["**/__tests__/**/*.test.js", "**/*.test.js"],
    "collectCoverageFrom": [
      "index.js",
      "routes/**/*.js",
      "services/**/*.js"
    ],
    "coverageDirectory": "coverage",
    "verbose": true
  }
}

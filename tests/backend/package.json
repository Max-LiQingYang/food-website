{
  "name": "food-website-backend-tests",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test": "jest --coverage",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.3.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.4"
  },
  "jest": {
    "rootDir": "../..",
    "testEnvironment": "node",
    "setupFilesAfterEnv": [],
    "testMatch": ["**/tests/backend/**/*.test.js"],
    "collectCoverageFrom": [
      "backend/**/*.js",
      "!backend/node_modules/**"
    ],
    "coverageProvider": "v8",
    "coverageDirectory": "tests/backend/coverage",
    "verbose": true
  }
}

{
  "name": "food-website-frontend-tests",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test": "jest --coverage",
    "test:watch": "jest --watch"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/vue3-jest": "^29.2.6",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "vue": "^3.4.21"
  },
  "jest": {
    "rootDir": "../..",
    "testEnvironment": "jsdom",
    "testMatch": ["**/tests/frontend/**/*.test.js"],
    "moduleFileExtensions": ["js", "json", "vue"],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/frontend/$1",
      "^frontend/(.*)$": "<rootDir>/frontend/$1",
      "\\.(css|less|scss|sass)$": "<rootDir>/tests/frontend/__mocks__/styleMock.js"
    },
    "transform": {
      "^.+\\.vue$": "<rootDir>/tests/frontend/vue-transform-wrapper.js",
      "^.+\\.js$": "<rootDir>/tests/frontend/js-transform-wrapper.js"
    },
    "setupFilesAfterEnv": ["<rootDir>/tests/frontend/jest.setup.js"],
    "collectCoverageFrom": [
      "frontend/components/**/*.vue",
      "frontend/pages/**/*.vue",
      "!**/node_modules/**",
      "!**/coverage/**"
    ],
    "coverageDirectory": "tests/frontend/coverage",
    "verbose": true
  }
}
